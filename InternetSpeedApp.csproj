<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <AssemblyName>InternetSpeedApp</AssemblyName>
    <RootNamespace>InternetSpeedApp</RootNamespace>
    <ApplicationIcon>app.ico</ApplicationIcon>
    <Version>1.1.0</Version>
    <Product>Internet Speed Monitor</Product>
    <AssemblyTitle>Internet Speed Monitor</AssemblyTitle>
    <Description>Floating internet speed monitor widget for Windows</Description>
    <Company>Md. Shakhawat Hossain Shahin</Company>
    <Copyright>© 2026 Md. Shakhawat Hossain Shahin</Copyright>
  </PropertyGroup>
</Project>
